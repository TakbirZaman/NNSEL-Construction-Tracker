# ─── Database ──────────────────────────────────────────────────────────────────
# Railway will set this automatically when you add the PostgreSQL plugin.
# For local dev, use your local PostgreSQL connection string.
DATABASE_URL=postgres://user:password@localhost:5432/constructtrack

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure random string: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins (optional).
# Railway URL is auto-allowed via the /\.railway\.app$/ regex.
CORS_ORIGIN=

# ─── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. This is only for local dev.
PORT=5000
NODE_ENV=production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (optional, defaults used otherwise)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
