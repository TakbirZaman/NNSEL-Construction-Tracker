# ─── Database ──────────────────────────────────────────────────────────────────
# Fly.io sets this automatically when you attach a PostgreSQL database.
# For local dev, use your local PostgreSQL connection string.
DATABASE_URL=postgres://user:password@localhost:5432/constructtrack

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Required. Generate a secure random string: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Extra allowed origin for production (optional).
# Frontend is served from the same origin, so this is only needed
# if you access the API from a different domain.
CORS_ORIGIN=

# ─── Server ────────────────────────────────────────────────────────────────────
# Fly.io sets PORT automatically (8080). This is only for local dev.
PORT=5000
NODE_ENV=production
