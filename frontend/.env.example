# ─── API ─────────────────────────────────────────────────────────────────────
# The URL of your backend (Express) server.
# In dev, this falls back to '/api' (proxied by Vite).
# In production, set this to your Railway backend URL (without trailing slash).
# Example: VITE_API_URL=https://constructtrack-backend.up.railway.app
VITE_API_URL=

# ─── WebSocket ───────────────────────────────────────────────────────────────
# The WebSocket URL for real-time updates.
# If not set, it is derived from VITE_API_URL (http→ws, https→wss).
# In dev, falls back to window.location.host + '/ws' (proxied by Vite).
# Example: VITE_WS_URL=wss://constructtrack-backend.up.railway.app
VITE_WS_URL=
